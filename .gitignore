# node
node_modules/
*.log
.npm
.pnpm-store/

# build
dist/
build/
*.tsbuildinfo

# env
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# python (aligner runs without venv but keep this so cwd activations don't leak)
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.venv/

# rust / tauri (when pipeline gets scaffolded)
target/

# secrets
*.pem
*.key

# aligner has its own repo at Worship_Suite/aligner/ — do not double-track
aligner/

# scratch space (1.3GB of venvs + raw audio) — never tracked
scratch/

# Demucs separation output — derived from a source recording, never
# track the bytes (GitHub flags anything > 50MB). The model name
# becomes the directory name under the producer's chosen output dir.
**/htdemucs/
**/htdemucs_ft/
**/mdx_extra/
**/mdx_extra_q/
**/mdx/

# WhisperX JSON output — derived from an audio input
**/*_whisperx.json

# Supabase CLI internal cache
supabase/.temp/
supabase/.branches/
