# Copy to .env.local and fill in. .env.local is gitignored.
# Values from Supabase dashboard:
#   Project ref: hnrjycpjcnlzqqunmdac
#   URL + keys:  https://supabase.com/dashboard/project/hnrjycpjcnlzqqunmdac/settings/api

SUPABASE_URL=https://hnrjycpjcnlzqqunmdac.supabase.co
SUPABASE_ANON_KEY=
# Server-side only. NEVER ship to the client. Used by Pipeline + admin scripts.
SUPABASE_SERVICE_ROLE_KEY=

# Browser-exposed mirrors of the above. Both Vite apps read these.
VITE_SUPABASE_URL=https://hnrjycpjcnlzqqunmdac.supabase.co
VITE_SUPABASE_ANON_KEY=

# auth.users uuid that Pipeline writes new song rows under (service-
# role insert; the FK against auth.users requires a real id).
WORSHIP_PRODUCER_USER_ID=

# OPTIONAL — Phase 7. Pin Pipeline's Python interpreter and the
# whisperx CLI to a working Python (e.g. a pyenv-managed 3.11) when
# the system `python3` is broken or doesn't have demucs/whisperx
# installed. Defaults to PATH lookup (`python3` / `whisperx`).
# PIPELINE_PYTHON_BIN=/Users/you/.pyenv/versions/3.11.9/bin/python3
# PIPELINE_WHISPERX_BIN=/Users/you/.pyenv/versions/3.11.9/bin/whisperx
