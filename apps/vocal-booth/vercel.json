{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm --filter @worship/vocal-booth build",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
